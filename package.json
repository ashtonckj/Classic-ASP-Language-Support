{
    "name": "classic-asp-language-support",
    "displayName": "Classic ASP Language Support",
    "description": "Complete language support for Classic ASP files with formatting, IntelliSense, snippets, and auto-completion for HTML, CSS, JavaScript, and VBScript.",
    "version": "0.3.0",
    "icon": "images/icon.png",
    "publisher": "ashtonckj",
    "repository": {
        "type": "git",
        "url": "https://github.com/ashtonckj/Classic-ASP-Language-Support.git"
    },
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Programming Languages",
        "Formatters",
        "Snippets",
        "Other"
    ],
    "keywords": [
        "ASP",
        "Classic",
        "Classic ASP",
        "Active Server Pages",
        "VBScript",
        "HTML",
        "CSS",
        "JavaScript",
        "SQL",
        "Syntax Highlighting",
        "Formatter",
        "Intellisense",
        "Autocomplete",
        "Snippets"
    ],
    "license": "MIT",
    "activationEvents": [
        "onLanguage:html"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "asp",
                "aliases": [
                    "ASP",
                    "Classic ASP",
                    "asp"
                ],
                "extensions": [
                    ".asp"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "scopeName": "text.html.asp",
                "path": "./syntaxes/asp.tmLanguage.json",
                "injectTo": [
                    "text.html.basic",
                    "text.html.derivative"
                ],
                "injectionSelector": "L:text.html.derivative, L:text.html.basic",
                "embeddedLanguages": {
                    "meta.embedded.block.asp": "vbscript",
                    "source.asp": "vbscript"
                }
            }
        ],
        "snippets": [
            {
                "language": "html",
                "path": "./snippets/asp.json"
            }
        ],
        "configurationDefaults": {
            "[html]": {
                "editor.quickSuggestions": {
                    "other": true,
                    "comments": false,
                    "strings": true
                }
            },
            "html.validate.scripts": false
        },
        "configuration": [
            {
                "title": "ASP Formatting",
                "properties": {
                    "aspLanguageSupport.keywordCase": {
                        "type": "string",
                        "default": "PascalCase",
                        "enum": [
                            "lowercase",
                            "UPPERCASE",
                            "PascalCase"
                        ],
                        "enumDescriptions": [
                            "if, then, end if, dim",
                            "IF, THEN, END IF, DIM",
                            "If, Then, End If, Dim"
                        ],
                        "description": "ASP/VBScript keyword formatting style"
                    },
                    "aspLanguageSupport.useTabs": {
                        "type": "boolean",
                        "default": false,
                        "description": "Use tabs instead of spaces for ASP code indentation"
                    },
                    "aspLanguageSupport.indentSize": {
                        "type": "number",
                        "default": 2,
                        "enum": [
                            2,
                            4,
                            8
                        ],
                        "description": "Number of spaces per indentation level for ASP code"
                    },
                    "aspLanguageSupport.tagsOnSameLine": {
                        "type": "boolean",
                        "default": false,
                        "description": "Keep <% and %> on same line as code (default: separate lines)"
                    }
                }
            },
            {
                "title": "HTML, CSS & JavaScript Formatting",
                "properties": {
                    "aspLanguageSupport.prettier.printWidth": {
                        "type": "number",
                        "default": 80,
                        "description": "Maximum line length (Prettier)"
                    },
                    "aspLanguageSupport.prettier.tabWidth": {
                        "type": "number",
                        "default": 2,
                        "enum": [
                            2,
                            4,
                            8
                        ],
                        "description": "Spaces per indentation level (Prettier)"
                    },
                    "aspLanguageSupport.prettier.useTabs": {
                        "type": "boolean",
                        "default": false,
                        "description": "Use tabs instead of spaces (Prettier)"
                    },
                    "aspLanguageSupport.prettier.bracketSameLine": {
                        "type": "boolean",
                        "default": true,
                        "description": "Put > of multi-line elements on last line (Prettier)"
                    },
                    "aspLanguageSupport.prettier.semi": {
                        "type": "boolean",
                        "default": true,
                        "description": "Add semicolons to JavaScript statements (Prettier)"
                    },
                    "aspLanguageSupport.prettier.singleQuote": {
                        "type": "boolean",
                        "default": false,
                        "description": "Use single quotes in JavaScript (Prettier)"
                    },
                    "aspLanguageSupport.prettier.arrowParens": {
                        "type": "string",
                        "default": "always",
                        "enum": [
                            "always",
                            "avoid"
                        ],
                        "enumDescriptions": [
                            "(x) => x",
                            "x => x"
                        ],
                        "description": "Arrow function parameter parentheses (Prettier)"
                    },
                    "aspLanguageSupport.prettier.trailingComma": {
                        "type": "string",
                        "default": "es5",
                        "enum": [
                            "none",
                            "es5",
                            "all"
                        ],
                        "enumDescriptions": [
                            "No trailing commas",
                            "ES5-valid locations only",
                            "Everywhere possible"
                        ],
                        "description": "Trailing comma style (Prettier)"
                    },
                    "aspLanguageSupport.prettier.endOfLine": {
                        "type": "string",
                        "default": "lf",
                        "enum": [
                            "lf",
                            "crlf",
                            "cr",
                            "auto"
                        ],
                        "enumDescriptions": [
                            "\\n (Linux/macOS)",
                            "\\r\\n (Windows)",
                            "\\r (rare)",
                            "Keep existing"
                        ],
                        "description": "Line ending style (Prettier)"
                    },
                    "aspLanguageSupport.prettier.htmlWhitespaceSensitivity": {
                        "type": "string",
                        "default": "css",
                        "enum": [
                            "css",
                            "strict",
                            "ignore"
                        ],
                        "enumDescriptions": [
                            "Respect CSS display property",
                            "Whitespace significant",
                            "Whitespace insignificant"
                        ],
                        "description": "HTML whitespace handling (Prettier)"
                    }
                }
            },
            {
                "title": "Syntax Highlighting",
                "properties": {
                    "aspLanguageSupport.enableSqlInStrings": {
                        "type": "boolean",
                        "default": true,
                        "markdownDescription": "Enable SQL syntax highlighting inside double-quoted strings. Toggle with `ASP: Toggle SQL Syntax Highlighting` command (requires reload)."
                    },
                    "aspLanguageSupport.enableAspRegions": {
                        "type": "boolean",
                        "default": true,
                        "description": "Highlight ASP code regions with background colors"
                    },
                    "aspLanguageSupport.bracketLightColor": {
                        "type": "string",
                        "default": "rgba(255, 100, 0, 0.2)",
                        "description": "ASP bracket <% %> color (light theme)"
                    },
                    "aspLanguageSupport.bracketDarkColor": {
                        "type": "string",
                        "default": "rgba(0, 100, 255, 0.2)",
                        "description": "ASP bracket <% %> color (dark theme)"
                    },
                    "aspLanguageSupport.codeBlockLightColor": {
                        "type": "string",
                        "default": "rgba(100, 100, 100, 0.1)",
                        "description": "ASP code block background (light theme)"
                    },
                    "aspLanguageSupport.codeBlockDarkColor": {
                        "type": "string",
                        "default": "rgba(220, 220, 220, 0.1)",
                        "description": "ASP code block background (dark theme)"
                    }
                }
            },
            {
                "title": "Validation & Diagnostics",
                "properties": {
                    "aspLanguageSupport.disableHtml": {
                        "type": "boolean",
                        "default": true,
                        "markdownDescription": "Disable HTML validation errors globally to prevent false errors from ASP code like `Response.Write(\"<script>\")` or VBScript's `<>` operator. **Note:** Affects all HTML files, not just .asp. CSS and JavaScript validation remain active."
                    }
                }
            },
            {
                "title": "IntelliSense & Completion",
                "properties": {
                    "aspLanguageSupport.enableAspCompletion": {
                        "type": "boolean",
                        "default": true,
                        "description": "Enable ASP object and VBScript keyword auto-completion"
                    }
                }
            }
        ],
        "commands": [
            {
                "command": "asp.toggleSQLHighlighting",
                "title": "ASP: Toggle SQL Syntax Highlighting in Strings"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src --ext ts",
        "test": "node ./out/test/runTest.js"
    },
    "dependencies": {
        "prettier": "^3.8.1"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "16.x",
        "@types/vscode": "^1.80.0",
        "@typescript-eslint/eslint-plugin": "^8.53.1",
        "@typescript-eslint/parser": "^8.53.1",
        "eslint": "^8.41.0",
        "typescript": "^5.0.4"
    }
}
